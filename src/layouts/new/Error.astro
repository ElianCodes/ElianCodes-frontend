---
import Layout from "./Generic.astro";

interface Props {
	title: string;
	description: string;
	noindex?: boolean;
}

const { title, description, noindex = true } = Astro.props;
---

<Layout {title} {description} {noindex}>
	<slot />
</Layout>

<style>
	html {
		background-color: var(--secondary);
	}
</style>

---
import { type CollectionEntry, render } from "astro:content";
import BlogPost from "@layouts/new/Blogpost.astro";
import { getSortedBlogPosts } from "@lib/content";

export async function getStaticPaths() {
	const blogEntries = await getSortedBlogPosts();
	return blogEntries.map((blogpost) => ({
		params: { slug: blogpost.id },
		props: { blogpost },
	}));
}

export interface Props {
	blogpost: CollectionEntry<"blog">;
}

const { blogpost } = Astro.props;
const { Content, headings } = await render(blogpost);
const socialImg = new URL(
	`/v1/generate/og/${Astro.params.slug ?? "default"}.png`,
	Astro.url,
);
---

<BlogPost
	post={blogpost.data}
	headings={headings}
	socialImg={socialImg}
	socialImgAlt={blogpost.data.title}
	socialImgWidth={1200}
	socialImgHeight={630}
>
	<Content />
</BlogPost>

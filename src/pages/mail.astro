---
// This page handles the mailto redirect client-side
// since Vercel doesn't handle mailto: redirects properly in vercel.json

import Button from "@components/ui/Button.astro";
import Section from "@components/ui/Section.astro";
import Subtitle from "@components/ui/Subtitle.astro";
import TitleSection from "@components/ui/TitleSection.astro";
import Layout from "@layouts/new/Default.astro";

const emailAddress = "hello@elian.codes";
const mailtoUrl = `mailto:${emailAddress}`;
---

<Layout title='Contact' description='Get in touch via email' noindex>
	<TitleSection title='Contact' subtitle='Get in touch via email.' />
	<Section class='mail-page'>
		<Subtitle class='mail-page__subtitle'>Opening your email client...</Subtitle>
		<p>
			<Button href={mailtoUrl} class='email-link'>
				Email me: {emailAddress}
			</Button>
		</p>
		<p class='mail-page__hint'>
			<small
				>If your email client didn't open automatically, click the button above.</small
			>
		</p>
	</Section>
</Layout>

<script>
	// Automatically redirect to email client when page loads
	document.addEventListener('DOMContentLoaded', function () {
		window.location.href = 'mailto:hello@elian.codes';
	});
</script>

<style>
	.mail-page {
		display: grid;
		justify-items: center;
		gap: 1rem;
		padding-top: 4rem;
		padding-bottom: 4rem;
		text-align: center;
	}

	.mail-page__subtitle {
		color: var(--text-muted);
	}

	.mail-page__hint {
		color: var(--text-muted);
	}
</style>

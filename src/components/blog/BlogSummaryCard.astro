---
import type { CollectionEntry } from "astro:content";
import SummaryCard from "@components/generic/SummaryCard.astro";
import { normalizeTag } from "@lib/content";
import Button from "@ui/Button.astro";
import Pill from "@ui/Pill.astro";

export interface Props {
	post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<SummaryCard
	title={post.data.title}
	imgAlt={post.data.title}
	imgSrc={post.data.imgUrl}
	description={post.data.description}
>
	<div class='blog-summary-card__tags'>
		<p class='blog-summary-card__label'>Tags</p>
		<ul class='blog-summary-card__tag-list'>
			{
				post.data.tags.map((tag) => {
					return (
						<li>
							<a href={`/blog/tags/${normalizeTag(tag)}/`}>
								<Pill>{tag}</Pill>
							</a>
						</li>
					);
				})
			}
		</ul>
	</div>

	<div class='blog-summary-card__footer'>
		<Button href={`/blog/${post.id}/`}>Read post</Button>
		{
			post.data.draft && (
				<span class='blog-summary-card__draft'>
					Draft
				</span>
			)
		}
	</div>
</SummaryCard>

<style>
	.blog-summary-card__footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: auto;
	}

	.blog-summary-card__draft {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.85rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: #d6f5a6;
		font-family: "Outfit", sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.blog-summary-card__tags {
		display: grid;
		gap: 0.65rem;
	}

	.blog-summary-card__label {
		font-family: "Outfit", sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.blog-summary-card__tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		list-style: none;
	}

	.blog-summary-card__tag-list a {
		text-decoration: none;
	}
</style>

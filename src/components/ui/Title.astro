---
import type { HTMLAttributes } from "astro/types";

export interface Props extends HTMLAttributes<"h1"> {
	as?: "h1" | "h2";
}

const { as: Tag = "h2", ...rest } = Astro.props as Props;
---
<Tag {...rest}>
	<slot />
</Tag>

<style>
	h1,
	h2 {
		text-transform: uppercase;
		color: var(--primary);
		font-weight: 700;
		font-size: 1.875rem;
		line-height: 2.25rem;
	}
	@media (min-width: 768px) {
		h1,
		h2 {
			font-size: 3.75rem; /* 60px */
			line-height: 1;
		}
	}
	@media (min-width: 1280px) {
		h1,
		h2 {
			font-size: 6rem; /* 96px */
			line-height: 1;
		}
	}
</style>

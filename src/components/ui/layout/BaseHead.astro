---
import SharedBaseHead from "@components/layout/BaseHead.astro";

export interface Props {
	title?: string;
	description?: string;
	socialImg?: URL;
}

const {
	title = "Elian Codes",
	description = "Elian Codes - Personal blog of Elian Van Cutsem",
	socialImg,
} = Astro.props;
---

<SharedBaseHead title={title} description={description} socialImg={socialImg}>
	<meta name='author' content='Elian Van Cutsem' />
</SharedBaseHead>

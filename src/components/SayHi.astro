---
import Button from "@ui/Button.astro";
import Section from "@ui/Section.astro";
import Title from "@ui/Title.astro";
---

<section class='say-hi-shell'>
	<Section id='say-hi' class='say-hi'>
		<Title>Let's do<br /> great things<br /> together.</Title>
		<div class='say-hi__copy'>
			<p>
				Hit me up if you want to collaborate, do a podcast or need an
				interesting talk/workshop!
			</p>
			<Button href='mailto:hello@elian.codes'>Say Hi!</Button>
		</div>
	</Section>
</section>

<style>
	.say-hi-shell {
		padding: 2rem 0;
	}

	.say-hi {
		display: grid;
		gap: 1.5rem;
		padding-top: 3rem;
		padding-bottom: 3rem;
		background: var(--light-gray);
		border: 1px solid var(--border);
		border-radius: var(--radius-xl);
		position: relative;
		z-index: 1;
	}

	.say-hi :global(h2) {
		color: var(--secondary);
	}

	.say-hi__copy {
		display: grid;
		gap: 1.25rem;
		align-content: center;
	}

	.say-hi__copy p {
		font-family: "Sanchez", serif;
		font-size: 1.1rem;
		line-height: 1.7;
	}

	@media (min-width: 900px) {
		.say-hi {
			grid-template-columns: minmax(0, 2fr) minmax(18rem, 1fr);
			align-items: center;
		}
	}
</style>
